    <style>
        :root { --primary: #002d5b; --accent: #007bff; --bg: #f0f4f8; --text: #2d3436; --white: #ffffff; }
        body { font-family: 'Inter', sans-serif; margin: 0; background-color: var(--bg); color: var(--text); line-height: 1.7; }
        .container { max-width: 1100px; margin: 0 auto; padding: 0 2rem; }
        
        header { background: var(--white); padding: 1.5rem 0; border-bottom: 3px solid var(--primary); position: sticky; top: 0; z-index: 1000; }
        .nav-flex { display: flex; justify-content: space-between; align-items: center; }
        .logo img { height: 85px; width: auto; vertical-align: middle; }
        nav a { text-decoration: none; color: var(--text); font-weight: 700; margin-left: 2rem; }

        .hero-mini { padding: 80px 0; background: var(--primary); color: white; text-align: center; }
        .content-box { background: var(--white); border-radius: 20px; padding: 4rem; margin: 40px 0; box-shadow: 0 15px 35px rgba(0,45,91,0.1); }
        
        h2 { font-size: 2.2rem; color: var(--primary); border-left: 6px solid var(--accent); padding-left: 20px; margin-bottom: 2rem; }
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2.5rem; }
        
        .mentor-card { background: #f8fbff; padding: 2.5rem; border-radius: 15px; border: 1px solid #e1e8f0; }
        .mentor-card h3 { color: var(--accent); margin-top: 0; }
        
        .btn { background: var(--accent); color: white; padding: 1.2rem 2.5rem; border-radius: 10px; text-decoration: none; font-weight: 700; display: inline-block; transition: 0.3s; margin-top: 20px; }
        .btn:hover { transform: translateY(-3px); box-shadow: 0 8px 20px rgba(0,123,255,0.4); }

